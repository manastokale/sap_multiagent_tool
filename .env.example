TOOLGEN_LLM_PROVIDER=gemini
TOOLGEN_LIVE_PROFILE=hybrid
TOOLGEN_RANDOMIZE_MODELS=false
TOOLGEN_REQUIRE_LIVE_LLM=false
TOOLGEN_LLM_REQUESTS_PER_MINUTE=10
TOOLGEN_MAX_PARALLEL_CONVERSATIONS=2
TOOLGEN_MAX_TURNS_PER_CONVERSATION=15
TOOLGEN_LLM_MAX_OUTPUT_TOKENS=256

# GEMINI_API_KEY=
# GROQ_API_KEY=

# Fallback model choices when role-specific pools are empty.
TOOLGEN_GENERATION_MODEL=gemini-3.1-flash-lite
TOOLGEN_JUDGE_MODEL=gemini-3.1-flash-lite

# Role-specific pools are blank so every live role uses gemini-3.1-flash-lite.
TOOLGEN_PLANNER_MODEL_POOL=
TOOLGEN_ASSISTANT_MODEL_POOL=
TOOLGEN_USER_MODEL_POOL=
TOOLGEN_SUMMARY_MODEL_POOL=
TOOLGEN_JUDGE_MODEL_POOL=

# Leave these blank unless you want a general randomized fallback pool.
TOOLGEN_GENERATION_MODEL_POOL=
